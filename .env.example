# ============================================================
# .env.example — Daisuki Confeitaria
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ─── Google Sheets ──────────────────────────────────────────
# The ID from your sheet URL:
# https://docs.google.com/spreadsheets/d/GOOGLE_SHEETS_ID/edit
GOOGLE_SHEETS_ID=your_sheet_id_here

# Service account email from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_EMAIL=daisuki-rifa@your-project.iam.gserviceaccount.com

# Private key from the downloaded JSON key file
# Keep the quotes and -----BEGIN/END lines intact
# Replace literal newlines with \n (Vercel does this automatically in the UI)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINES_HERE\n-----END RSA PRIVATE KEY-----"

# Optional: Google Project ID
GOOGLE_PROJECT_ID=your-gcp-project-id

# Optional: Private Key ID from the JSON credentials
GOOGLE_PRIVATE_KEY_ID=your_private_key_id

# ─── Admin panel ────────────────────────────────────────────
# Change this to a strong password before deploy!
ADMIN_KEY=daisuki_admin_2026
